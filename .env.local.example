# ─────────────────────────────────────────────────────────────
# Firebase (cliente) — se exponen al navegador (prefijo NEXT_PUBLIC)
# Console → Project settings → General → Your apps → SDK setup
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ─────────────────────────────────────────────────────────────
# Firebase Admin (servidor) — NUNCA se exponen al navegador
# Console → Project settings → Service accounts → Generate new private key
# Pega la private key entre comillas, con los \n literales.
# ─────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=""

# ─────────────────────────────────────────────────────────────
# Vercel Blob (almacenamiento de imágenes) — opcional en v1
# ─────────────────────────────────────────────────────────────
BLOB_READ_WRITE_TOKEN=

# ─────────────────────────────────────────────────────────────
# Notificación por email de nuevos leads (Resend) — opcional
# resend.com → API Keys. NOTIFY_EMAIL admite varios separados por coma.
# NOTIFY_FROM requiere dominio verificado; si no, usa onboarding@resend.dev.
# ─────────────────────────────────────────────────────────────
RESEND_API_KEY=
NOTIFY_EMAIL=mauricio.nubolabs@gmail.com
NOTIFY_FROM="Nubolabs <onboarding@resend.dev>"
